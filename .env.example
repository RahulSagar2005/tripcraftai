# TripCraft AI - Environment Variables (EXAMPLE)
# Copy this file to .env and fill in your API keys
# NEVER commit .env with real keys to git!

# Flask Secret Key (change in production)
SECRET_KEY=your-secret-key-change-in-production

# MongoDB Connection (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/tripcraft

# === FREE LLM OPTIONS (pick one or more) ===

# Option 1: Ollama (LOCAL - Completely Free, No API Key Needed)
# Install: https://ollama.ai
# Run: ollama pull llama3.2
# No environment variable needed - runs on localhost:11434

# Option 2: Hugging Face Inference API (Free Tier)
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_hf_api_key_here

# Option 3: OpenRouter (Free Models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Option 4: Google Gemini (Free Tier Available)
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# === FREE TRAVEL APIs ===

# SerpAPI - Free 100 searches/month (Google Flights, Hotels, Maps)
# Get key: https://serpapi.com/users/signup
SERPAPI_KEY=your_serpapi_key_here

# Exa API - Free 1000 searches/month (alternative search)
# Get key: https://exa.ai/
EXA_API_KEY=your_exa_api_key_here

# FireCrawl - Web scraping (optional)
# Get key: https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_key_here
